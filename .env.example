# Copy to .env.local (dev) or .env.production, fill in real values.
# Never commit the filled-in file — .env* is gitignored.

NODE_ENV=development
PORT=8000

# --- Database (required) ---
# db.config.js reads the first of these that's set, in order.
MONGODB_URI=mongodb://localhost:27017/saralbuy

# --- Auth (required in production; falls back to an insecure dev default
# with a console warning if unset locally — see src/config/secrets.js) ---
JWT_SECRET=
JWT_EXPIRES_IN=30d

# --- CORS / cross-app URLs ---
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# --- Redis (optional — caching degrades to in-memory fallback if unset) ---
REDIS_URL=

# --- ImageKit (optional — file uploads fall back to storing raw buffers
# in MongoDB if unset; fine for local dev, not for production) ---
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
BACKEND_URL=http://localhost:8000

# --- SMS/OTP provider (production only — NODE_ENV=development routes
# send-otp/verify-otp to a testable stub instead, see src/routes/user.route.js) ---
FACTOR_MESSAGE_API=

# --- Marketplace config ---
PLATFORM_COMMISSION_RATE=2
